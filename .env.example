# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
# Or use other compatible APIs (e.g., OpenRouter, Together AI, etc.)
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_STYLE=responses
OPENAI_USE_JSON_SCHEMA=0
OPENAI_MODEL=qwen3.5:0.8b
OPENAI_REPORT_MODEL=qwen3.5:0.8b
# 双屏可配置为：SCREENSHOT_DISPLAYS=1,2
# 自动探测时最多尝试显示器数量（默认 6）：SCREENSHOT_MAX_DISPLAYS=6
# 是否自动请求屏幕录制权限（默认 1）：SCREENSHOT_REQUEST_PERMISSION=1
# 是否严格要求权限（默认 0，建议保持）：SCREENSHOT_STRICT_PERMISSION=0
