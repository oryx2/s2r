{
  "name": "screen2report",
  "version": "0.2.0",
  "description": "本地模型服务管理工具（macOS）- TypeScript 重构版本",
  "main": "dist/index.js",
  "bin": {
    "s2r": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "pkg": "pkg dist/cli.js --targets node18-macos-arm64 --output dist/s2r",
    "pkg:x64": "pkg dist/cli.js --targets node18-macos-x64 --output dist/s2r"
  },
  "keywords": ["screen-capture", "llm", "report", "macos"],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  }
}
